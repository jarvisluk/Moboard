{
  "name": "moboard",
  "version": "1.0.10",
  "description": "Moboard is a cross-device voice dictation keyboard that lets you type on your computer using your mobile phone's voice recognition.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "test": "node --check main.js && node --check server.js && node --check scripts/afterSign.js && node --check scripts/build-mobile-pages.js && node --check public/js/desktop.js && node --check public/js/mobile.js",
    "build:icons": "node scripts/build-icons.js",
    "build:mobile-pages": "node scripts/build-mobile-pages.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --x64",
    "dist:mac:signed": "macos-signed bash scripts/dist-mac-signed.sh",
    "deploy:cloudflare:create": "wrangler pages project create moboard --production-branch=main",
    "deploy:cloudflare": "npm run build:mobile-pages && wrangler pages deploy dist-pages --project-name=moboard",
    "release:tag": "bash scripts/release.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "author": "Moboard",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "sharp": "^0.34.5",
    "wrangler": "^4.104.0"
  },
  "build": {
    "appId": "app.moboard.desktop",
    "productName": "Moboard",
    "afterSign": "scripts/afterSign.js",
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "hardenedRuntime": true,
      "icon": "assets/app-icon.icns",
      "category": "public.app-category.utilities",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Moboard uses System Events to paste dictated text into the active app."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Moboard"
    },
    "dmg": {
      "title": "Moboard",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
